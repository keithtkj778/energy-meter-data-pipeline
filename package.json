{
  "name": "energy-meter-data-pipeline",
  "version": "0.1.0",
  "description": "Convert NEM12 meter-reading files into PostgreSQL INSERT statements for the meter_readings table.",
  "main": "dist/index.js",
  "bin": {
    "nem12-parser": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
